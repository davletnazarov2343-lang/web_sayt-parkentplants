# Sanity CMS (BLOK 3)
# Olish uchun: https://www.sanity.io/manage da loyiha yarating
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Yashirin token — faqat draft preview yoki write uchun (hozir ishlatilmaydi)
SANITY_API_READ_TOKEN=

# ============================================================
# Supabase (BLOK 4) — leadlar saqlash
# https://supabase.com/dashboard da yangi loyiha yarating
# Project Settings -> API dan keylarni olasiz
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# DIQQAT: bu yashirin key, faqat server-side ishlatiladi. Hech qachon clientga chiqarmang.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Bitrix24 (BLOK 4) — leadlar CRM ga avtomatik yuboriladi
# https://YOUR_PORTAL.bitrix24.com -> Developers -> Other -> Inbound webhook
# crm.lead.add huquqini bering. Slash bilan tugaydigan to'liq URL ni qo'ying.
# ============================================================
BITRIX_WEBHOOK_URL=

# ============================================================
# Analytics (TIER 2 SEO) — har biri ixtiyoriy, env yo'q bo'lsa skript yuklanmaydi
# ============================================================
# Google Analytics 4 — analytics.google.com -> Admin -> Property -> Data Streams
NEXT_PUBLIC_GA_ID=
# Yandex Metrika — metrica.yandex.com -> +Counter (Counter ID)
NEXT_PUBLIC_YANDEX_METRIKA_ID=
# Meta Pixel — business.facebook.com -> Events Manager -> Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=
